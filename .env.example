# ─── Copy this file to .env and fill in values ────────────────────────────────
# Never commit .env — it is in .gitignore

# App API
EXPO_PUBLIC_API_URL=https://cathartic-api-250412160419.us-central1.run.app

# Firebase / Google Analytics (GA4)
# Create a project at console.firebase.google.com
# Link it to your existing GA4 property in Studio Catharsis Google Workspace
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=
EXPO_PUBLIC_FIREBASE_MEASUREMENT_ID=

# RevenueCat (free up to $2.5k MRR)
# Create one project at app.revenuecat.com for all Studio Catharsis apps
EXPO_PUBLIC_REVENUECAT_IOS_KEY=
EXPO_PUBLIC_REVENUECAT_ANDROID_KEY=

# Sentry (optional — crash reporting)
EXPO_PUBLIC_SENTRY_DSN=
